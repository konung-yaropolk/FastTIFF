# Maintainer: konung_yaropolk
# Builds FastTIFF from git. The version is read from FastTIFF/Cargo.toml by
# pkgver() (a tarball source can't, since the URL would need the version up
# front). Used for AUR and by the Arch job in .github/workflows/release.yml,
# which pins the checkout to the released tag.
pkgname=fasttiff
pkgver=0
pkgrel=1
pkgdesc="A lightning-fast multi-frame TIFF viewer with ImageJ-compatible rendering"
arch=('x86_64')
url="https://github.com/konung-yaropolk/FastTIFF"
license=('GPL-3.0-only')
# Runtime libs the glow GUI links (winit X11/Wayland + rfd GTK3 + OpenGL).
# Trim with `namcap` against the built package if you want a minimal set.
depends=('gcc-libs' 'glibc' 'gtk3' 'libglvnd' 'libxkbcommon'
         'libx11' 'libxcursor' 'libxi' 'libxrandr' 'wayland' 'fontconfig')
makedepends=('rust' 'git')
# Strip the binary but don't split symbols into a separate fasttiff-debug
# package — so the release only gets the one .pkg.tar.zst.
options=('!debug' 'strip')
source=("$pkgname::git+$url.git")
sha256sums=('SKIP')

pkgver() {
    # The crate version from the app's Cargo.toml (the workspace root has none).
    awk -F'"' '/^version[[:space:]]*=/ {print $2; exit}' "$srcdir/$pkgname/FastTIFF/Cargo.toml"
}

prepare() {
    cd "$pkgname"
    # Reconcile only the bumped workspace version into Cargo.lock: --workspace
    # leaves every external dependency at its locked version, so the build stays
    # reproducible while --locked/--frozen below no longer fail when the
    # committed lock lags a version bump.
    cargo update --workspace
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$pkgname"
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release -p FastTIFF
}

package() {
    cd "$pkgname"
    install -Dm755 target/release/FastTIFF "$pkgdir/usr/bin/FastTIFF"
    # Lowercase convenience name.
    ln -s FastTIFF "$pkgdir/usr/bin/fasttiff"
    # Desktop menu launcher + hicolor icons (pacman hooks refresh the caches).
    install -Dm644 FastTIFF/packaging/fasttiff.desktop "$pkgdir/usr/share/applications/fasttiff.desktop"
    install -Dm644 FastTIFF/icon/icon16.png "$pkgdir/usr/share/icons/hicolor/16x16/apps/fasttiff.png"
    install -Dm644 FastTIFF/icon/icon32.png "$pkgdir/usr/share/icons/hicolor/32x32/apps/fasttiff.png"
    install -Dm644 FastTIFF/icon/icon48.png "$pkgdir/usr/share/icons/hicolor/48x48/apps/fasttiff.png"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
